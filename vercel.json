{
  "framework": "vite",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm exec vite build",
  "outputDirectory": "dist/public",
  "crons": [
    {
      "path": "/api/cron-daily-content",
      "schedule": "0 1 * * *"
    }
  ],
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
